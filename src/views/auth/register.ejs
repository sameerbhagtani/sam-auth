<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Register | SamAuth</title>
        <link rel="stylesheet" href="/css/register.css" />
    </head>
    <body>
        <main class="page-shell">
            <section class="card register-card">
                <div class="card__eyebrow">SamAuth</div>
                <h1 class="card__title">Create your account</h1>

                <form class="form-grid" method="POST" action="/auth/register">
                    <input
                        type="hidden"
                        name="client_id"
                        value="<%= authorizeQuery.client_id %>"
                    />
                    <input
                        type="hidden"
                        name="redirect_uri"
                        value="<%= authorizeQuery.redirect_uri %>"
                    />
                    <input
                        type="hidden"
                        name="scope"
                        value="<%= authorizeQuery.scope %>"
                    />
                    <input
                        type="hidden"
                        name="response_type"
                        value="<%= authorizeQuery.response_type %>"
                    />
                    <input
                        type="hidden"
                        name="state"
                        value="<%= authorizeQuery.state %>"
                    />

                    <div class="field">
                        <label for="firstName">First name</label>
                        <input
                            id="firstName"
                            name="firstName"
                            type="text"
                            placeholder="Sameer"
                            autocomplete="given-name"
                            required
                            minlength="1"
                            maxlength="50"
                        />
                    </div>

                    <div class="field">
                        <label for="lastName">Last name</label>
                        <input
                            id="lastName"
                            name="lastName"
                            type="text"
                            placeholder="Bhagtani"
                            autocomplete="family-name"
                            maxlength="50"
                        />
                    </div>

                    <div class="field">
                        <label for="registerEmail">Email</label>
                        <input
                            id="registerEmail"
                            name="email"
                            type="email"
                            placeholder="you@example.com"
                            autocomplete="email"
                            required
                            maxlength="255"
                        />
                    </div>

                    <div class="field">
                        <label for="registerPassword">Password</label>
                        <input
                            id="registerPassword"
                            name="password"
                            type="password"
                            placeholder="Create a password"
                            autocomplete="new-password"
                            required
                            minlength="6"
                            maxlength="72"
                            pattern="^(?=.*[a-zA-Z])(?=.*\d)(?=.*[\W_]).{6,}$"
                            title="Use at least 6 characters with letters, numbers, and symbols."
                        />
                    </div>

                    <button class="btn btn-primary" type="submit">
                        Create account
                    </button>
                </form>

                <div class="auth-links">
                    <a href="<%= "/auth/login?client_id=" + encodeURIComponent(authorizeQuery.client_id) + "&redirect_uri=" + encodeURIComponent(authorizeQuery.redirect_uri) + "&scope=" + encodeURIComponent(authorizeQuery.scope) + "&response_type=" + encodeURIComponent(authorizeQuery.response_type) + "&state=" + encodeURIComponent(authorizeQuery.state) %>">Already have an account? Sign in</a>
                </div>
            </section>
        </main>
        <script src="/js/auth.js"></script>
    </body>
</html>
